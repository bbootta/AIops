      "model_types": ["scoring", "pd"],
      "direction": "higher_is_better",
      "green_threshold": 0.50,
      "yellow_threshold": 0.30
    },
    "psi": {
      "model_types": ["scoring", "pd", "monitoring"],
      "direction": "lower_is_better",
      "green_threshold": 0.10,
      "yellow_threshold": 0.25
    },
    "brier": {
      "model_types": ["pd"],
      "direction": "lower_is_better",
      "green_threshold": 0.10,
      "yellow_threshold": 0.20
