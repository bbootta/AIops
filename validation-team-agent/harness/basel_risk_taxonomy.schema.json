{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://validation-team-agent/basel_risk_taxonomy.schema.json",
  "title": "Basel Risk Taxonomy",
  "type": "object",
  "properties": {
    "taxonomy_version": { "type": "string" },
    "framework": { "type": "string" },
    "description": { "type": "string" },
    "risk_buckets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "capital_adequacy",
              "credit",
              "ifrs9",
              "market",
              "operational",
              "liquidity",
              "irrbb",
              "cva",
              "ccr"
            ]
          },
          "title": { "type": "string", "minLength": 1 },
          "basel_refs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "policy": { "type": "string" },
          "thresholds": { "type": "string" },
          "key_metrics": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "tools": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        },
        "required": ["id", "title", "basel_refs", "policy", "key_metrics", "tools"],
        "additionalProperties": false
      }
    }
  },
  "required": ["taxonomy_version", "framework", "risk_buckets"],
  "additionalProperties": false
}
