{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://validation-team-agent/permission_matrix.schema.json",
  "title": "Permission Matrix",
  "description": "SSoT for permission_guard's dangerous-pattern catalog.",
  "type": "object",
  "properties": {
    "matrix_version": { "type": "string" },
    "description": { "type": "string" },
    "patterns": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/pattern" }
    }
  },
  "required": ["matrix_version", "patterns"],
  "additionalProperties": false,
  "$defs": {
    "pattern": {
      "type": "object",
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "destructive_fs",
            "force_push",
            "hard_reset",
            "skip_hook",
            "ops_db",
            "external_io",
            "credential_exposure"
          ]
        },
        "regex": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      },
      "required": ["category", "regex"],
      "additionalProperties": false
    }
  }
}
