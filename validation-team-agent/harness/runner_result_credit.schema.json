{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://validation-team-agent/runner_result_credit.schema.json",
  "title": "Credit Runner Result",
  "description": "tools/run_validation.run() 결과의 핵심 필드 + quant 서브트리.",
  "type": "object",
  "properties": {
    "report_md": { "type": "string", "minLength": 1 },
    "completeness": {
      "type": "object",
      "properties": { "passed": { "type": "boolean" } },
      "required": ["passed"]
    },
    "citations": {
      "type": "object",
      "properties": { "passed": { "type": "boolean" } },
      "required": ["passed"]
    },
    "watermarks": {
      "type": "object",
      "properties": { "passed": { "type": "boolean" } },
      "required": ["passed"]
    },
    "quant": {
      "type": "object",
      "properties": {
        "sample_size": {
          "type": "object",
          "properties": { "passed": { "type": "boolean" } },
          "required": ["passed"]
        }
      },
      "required": ["sample_size"]
    }
  },
  "required": ["report_md", "completeness", "citations", "watermarks", "quant"]
}
